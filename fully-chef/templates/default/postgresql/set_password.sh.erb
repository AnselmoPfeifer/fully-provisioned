#!/usr/bin/env bash

sudo -i << EOF
    set -x
    su <%= @default_username %>
    cd /var/lib/postgresql/
    psql -c "ALTER ROLE postgres WITH PASSWORD '<%= @default_password %>';"
    exit
EOF

<% if node['postgresql']['replication'] %>
if [ ! -f /var/lib/postgresql/pg_<%= @replication_username %>.txt ]; then
  sudo -i << EOF
    set -x
    echo 'Creating a replication user!'
    su <%= @default_username %>
    cd /var/lib/postgresql/
    psql -c "CREATE USER <%= @replication_username %> REPLICATION LOGIN CONNECTION LIMIT 1 ENCRYPTED PASSWORD '<%= @replication_password %>';"
    touch pg_<%= @replication_username %>.txt
    exit
EOF
else
  echo 'Skipping replication user!'
fi
<% end -%>